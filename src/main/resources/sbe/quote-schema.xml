<?xml version="1.0" encoding="UTF-8"?>
<sbe:messageSchema xmlns:sbe="http://fixprotocol.io/2016/sbe"
                   package="com.etrade.gateway.sbe"
                   id="1"
                   version="1"
                   semanticVersion="1.0.0"
                   description="Quote Message Schema"
                   byteOrder="littleEndian">

    <types>
        <composite name="messageHeader" description="Message identifiers and length of message root.">
            <type name="blockLength" primitiveType="uint16"/>
            <type name="templateId" primitiveType="uint16"/>
            <type name="schemaId" primitiveType="uint16"/>
            <type name="version" primitiveType="uint16"/>
        </composite>

        <enum name="BooleanType" encodingType="uint8" nullValue="255">
            <validValue name="FALSE">0</validValue>
            <validValue name="TRUE">1</validValue>
        </enum>

        <composite name="varStringEncoding">
            <type name="length" primitiveType="uint32" maxValue="1048576"/>
            <type name="varData" primitiveType="uint8" length="0" characterEncoding="UTF-8"/>
        </composite>
    </types>

    <sbe:message name="Quote" id="1" description="Market Quote Message">
        <!-- Fixed-length fields first -->
        <field name="bid" id="1" type="double"/>
        <field name="ask" id="2" type="double"/>
        <field name="valid" id="3" type="BooleanType"/>
        <field name="validFrom" id="4" type="int64"/>
        <field name="validTill" id="5" type="int64"/>

        <!-- Variable-length fields -->
        <data name="rateType" id="6" type="varStringEncoding"/>
        <data name="rateQuoteID" id="7" type="varStringEncoding"/>
        <data name="rateCategoryID" id="8" type="varStringEncoding"/>
        <data name="baseCurrency" id="9" type="varStringEncoding"/>
        <data name="quoteCurrency" id="10" type="varStringEncoding"/>
        <data name="tenor" id="11" type="varStringEncoding"/>
        <data name="status" id="12" type="varStringEncoding"/>
    </sbe:message>

</sbe:messageSchema>
